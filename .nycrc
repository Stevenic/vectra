{
  "extension": [
    ".ts"
  ],
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "**/node_modules/**",
    "**/tests/**",
    "**/coverage/**",
    "**/*.d.ts",
    "**/internals/**",
    "**/*.spec.ts",
    "**/index.ts"
  ],
  "reporter": [
    "html",
    "lcov",
    "text"
  ],
  "all": true,
  "cache": true
}
